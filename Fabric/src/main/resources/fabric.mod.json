{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contributors": [
    "${mod_credits}"
  ],
  "contact": {
    "homepage": "https://github.com/${mod_author}/${mod_name}",
    "issues": "https://github.com/${mod_author}/${mod_name}/issues",
    "sources": "https://github.com/${mod_author}/${mod_name}"
  },
  "license": "${license}",
  "icon": "${mod_id}_icon.png",
  "environment": "*",
  "accessWidener": "${mod_id}.accesswidener",
  "entrypoints": {
    "main": [
      "${mod_id}.${mod_name}Fabric"
    ],
    "client": [
      "${mod_id}.${mod_name}ClientFabric"
    ],
    "fabric-datagen": [
      "${mod_id}.data.FabricDatagenInitializer"
    ],
    "whitenoise-config": [
      "${mod_id}.FabricConfigInitializer"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": "${fabric_loader_min_version}",
    "fabric-api": "${fabric_api_min_version}",
    "minecraft": ${fabric_mc_version_range},
    "whitenoise": ${fabric_whitenoise_range},
    "java": ">=${java_version}"
  }
}
